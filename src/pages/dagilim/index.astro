---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import IznimvarBanner from '../../components/IznimvarBanner.astro';
import '../../styles/global.css';
import SalaryScatter from '../../components/SalaryScatter';
---

<Layout title="Deneyim ve Maaş Dağılımı - BT Maaş Endeksi" active="dagilim" description="5.002 yazılımcının deneyim-maaş dağılımını keşfet. Şehir bazında filtreleme.">
  <section class="max-w-[960px] mx-auto px-6 pt-16 pb-8">
    <h1 class="text-3xl font-bold text-text tracking-tight mb-3">Deneyim ve Maaş Dağılımı</h1>
    <p class="text-base text-text-secondary leading-relaxed mb-4">
      Aşağıdaki grafikte 5.002 yazılımcının her biri tek bir nokta olarak gösteriliyor.
      Yatay eksen sektördeki deneyim süresini, dikey eksen ise aylık net maaşı temsil ediyor.
      Renklendirme seviyeye göre yapıldı: junior, orta ve senior geliştiriciler farklı tonlarla ayrışıyor.
    </p>
    <p class="text-sm text-text-muted leading-relaxed mb-8">
      Şehir filtresiyle kendi bölgenizdeki dağılımı inceleyebilir, deneyim yılına göre maaşınızın
      genel ortalamanın neresinde durduğunu görebilirsiniz. Noktaların yoğunlaştığı bölgeler,
      o deneyim aralığındaki tipik maaş düzeyini yansıtıyor.
    </p>

    <div class="bg-bg-white rounded-xl shadow-sm p-6">
      <SalaryScatter client:load />
    </div>
  </section>

  <IznimvarBanner />
  <Footer />
</Layout>
