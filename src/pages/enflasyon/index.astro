---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import IznimvarBanner from '../../components/IznimvarBanner.astro';
import '../../styles/global.css';

// ENAG vs TUIK annual inflation rates
const inflationData = [
  { year: 2018, tuik: 20.3, enag: null },
  { year: 2019, tuik: 11.8, enag: null },
  { year: 2020, tuik: 14.6, enag: 36.7 },
  { year: 2021, tuik: 36.1, enag: 82.8 },
  { year: 2022, tuik: 72.3, enag: 137.6 },
  { year: 2023, tuik: 53.9, enag: 127.2 },
  { year: 2024, tuik: 44.4, enag: 110.0 },
  { year: 2025, tuik: 30.9, enag: 56.1 },
];

// Cumulative multipliers since 2018
const years = [2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025, 2026];
const enagCumulative = [1, 1.35, 1.85, 3.2, 10.8, 22.5, 38.4, 59.6, 78.5];
const tuikCumulative = [1, 1.12, 1.27, 1.63, 3.81, 6.48, 10.1, 14.2, 18.6];

// Junior salary: nominal vs ENAG-adjusted
const junior2018 = 3000;
const nominalJunior = [3000, 3500, 4500, 5500, 8500, 17500, 34500, 49500, 65500];
const enagAdjusted = enagCumulative.map(m => Math.round(junior2018 * m));
const purchasingPowerLoss = Math.round((1 - nominalJunior[8] / enagAdjusted[8]) * 100);

// Mid-level salary for tantuni calculation
const nominalMid = [4500, 5500, 6500, 8500, 13500, 26500, 50500, 74500, 102500];

// Tantuni Index (Istanbul, et tantuni dürüm average price)
const tantuniPrices = [10, 12, 15, 22, 45, 90, 150, 200, 250]; // TRY
const tantuniPerSalary = nominalMid.map((sal, i) => ({
  year: years[i],
  count: Math.round(sal / tantuniPrices[i]),
  price: tantuniPrices[i],
  salary: sal,
}));

// Tax rates by country (mid-level developer, employee-side + Turkey breakdown)
// TR mid-level: ₺102.500 net/ay x 12 / 37 = $33.200/yıl net
const taxData = [
  { country: 'Estonya', flag: '🇪🇪', rate: 24, netUSD: 56000 },
  { country: 'İsviçre', flag: '🇨🇭', rate: 24, netUSD: 106000 },
  { country: 'İngiltere', flag: '🇬🇧', rate: 30, netUSD: 96000 },
  { country: 'ABD', flag: '🇺🇸', rate: 32, netUSD: 82000 },
  { country: 'İspanya', flag: '🇪🇸', rate: 32, netUSD: 37000 },
  { country: 'Japonya', flag: '🇯🇵', rate: 32, netUSD: 39000 },
  { country: 'Hollanda', flag: '🇳🇱', rate: 38, netUSD: 61000 },
  { country: 'Türkiye (maaşlı çalışan)', flag: '🇹🇷', rate: 39, netUSD: 33200, highlight: true },
  { country: 'Almanya', flag: '🇩🇪', rate: 40, netUSD: 54000 },
  { country: 'Danimarka', flag: '🇩🇰', rate: 40, netUSD: 60000 },
  { country: 'TR serbest meslek (freelancer)', flag: '🇹🇷', rate: 42, netUSD: 29000, highlight: true },
  { country: 'TR şirket sahibi (tahmini)', flag: '🇹🇷', rate: 45, netUSD: 22000, highlight: true },
];

// Turkey hidden tax breakdown for detail section
const turkeyTaxBreakdown = [
  { name: 'Gelir vergisi (GV)', rate: '15-40', note: 'Artan oranlı; ₺158K\'ya kadar %15, ₺330K-1,2M arası %27, ₺4,3M üzeri %40' },
  { name: 'SGK işçi payı', rate: '14', note: 'Brüt maaş üzerinden, tavan sınırına tabi' },
  { name: 'SGK işveren payı', rate: '20,75', note: 'İşveren tarafı; çalışana yansımaz ama toplam istihdam maliyetini artırır' },
  { name: 'İşsizlik sigortası (işçi)', rate: '1', note: 'Brüt maaş üzerinden işçi payı' },
  { name: 'Damga vergisi', rate: '0,759', note: 'Her maaş ödemesinde kesilen sabit oran' },
  { name: 'Stopaj (serbest meslek)', rate: '20', note: 'Yalnızca serbest meslek erbabına uygulanır; gelir vergisinden mahsup edilir' },
  { name: 'Kurumlar vergisi', rate: '25', note: 'Şirket net karı üzerinden (2025 itibarıyla)' },
  { name: 'KDV', rate: '20', note: 'Müşteriden tahsil edilir; doğrudan kar üzerinden hesaplanmaz' },
  { name: 'Geçici vergi', rate: '25', note: 'Kurumlar vergisinin üç aylık peşin ödemesi; ayrı bir vergi değildir' },
];

// Rent-to-salary ratio (1BR city center, mid-level dev)
const rentData = [
  { city: 'San Francisco', flag: '🇺🇸', rent: 3413, salary: 10000, ratio: 34 },
  { city: 'Londra', flag: '🇬🇧', rent: 3134, salary: 9000, ratio: 35 },
  { city: 'Amsterdam', flag: '🇳🇱', rent: 2591, salary: 8333, ratio: 31 },
  { city: 'İstanbul', flag: '🇹🇷', rent: 1083, salary: 2500, ratio: 43 },
  { city: 'Berlin', flag: '🇩🇪', rent: 1456, salary: 7500, ratio: 19 },
  { city: 'Kopenhag', flag: '🇩🇰', rent: 1800, salary: 8333, ratio: 22 },
  { city: 'Tokyo', flag: '🇯🇵', rent: 1130, salary: 4750, ratio: 24 },
  { city: 'Madrid', flag: '🇪🇸', rent: 1200, salary: 4583, ratio: 26 },
  { city: 'Tallinn', flag: '🇪🇪', rent: 850, salary: 6167, ratio: 14 },
];

const sortedRent = [...rentData].sort((a, b) => b.ratio - a.ratio);
const maxRatio = Math.max(...sortedRent.map(r => r.ratio));
---

<Layout title="Enflasyon ve Satın Alma Gücü - BT Maaş Endeksi" active="enflasyon" description="Yazılımcı maaşları enflasyona yetişebildi mi? ENAG vs TUIK, vergi yükü, kira/maaş oranı ve satın alma gücü analizi.">
  <section class="max-w-[960px] mx-auto px-6 pt-16 pb-4">
    <h1 class="text-3xl font-bold text-text tracking-tight mb-2">Yazılımcı Maaşları ve Enflasyon</h1>
    <p class="text-base text-text-secondary leading-relaxed mb-4">
      2018'den bu yana yazılımcı maaşları nominal olarak 16 kat arttı. Ancak bağımsız
      enflasyon verileri (ENAG) farklı bir tablo çiziyor: aynı dönemde fiyatlar
      yaklaşık 60 kat yükseldi. Bir başka deyişle, maaş zammı yalnızca enflasyonun
      dörtte birini karşılayabildi.
    </p>
    <p class="text-sm text-text-muted leading-relaxed mb-10">
      Bu sayfa, resmi (TÜİK) ve bağımsız (ENAG) enflasyon verilerini karşılaştırarak
      yazılımcının gerçek satın alma gücündeki erimenin boyutunu ortaya koyuyor.
      Vergi yükü ve kira oranlarıyla birlikte değerlendirildiğinde, nominal maaş
      artışlarının neden "hissedilmediği" anlaşılıyor.
    </p>
  </section>

  <!-- KPI Cards -->
  <section class="max-w-[960px] mx-auto px-6 pb-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
      <div class="bg-bg-white rounded-xl shadow-sm p-5 text-center">
        <div class="text-3xl font-black text-chart-4 font-mono mb-1">%{purchasingPowerLoss}</div>
        <div class="text-xs text-text-muted">Satın alma gücü kaybı</div>
        <div class="text-[10px] text-text-dim mt-0.5">ENAG'a göre, 2018'den bu yana</div>
      </div>
      <div class="bg-bg-white rounded-xl shadow-sm p-5 text-center">
        <div class="text-3xl font-black text-accent font-mono mb-1">16x</div>
        <div class="text-xs text-text-muted">Nominal maaş artışı</div>
        <div class="text-[10px] text-text-dim mt-0.5">Junior: ₺3.000'dan ₺49.500'e</div>
      </div>
      <div class="bg-bg-white rounded-xl shadow-sm p-5 text-center">
        <div class="text-3xl font-black text-chart-3 font-mono mb-1">59.6x</div>
        <div class="text-xs text-text-muted">ENAG kümülatif enflasyon</div>
        <div class="text-[10px] text-text-dim mt-0.5">2018-2025 (%5.864)</div>
      </div>
      <div class="bg-bg-white rounded-xl shadow-sm p-5 text-center">
        <div class="text-3xl font-black text-text font-mono mb-1">%43</div>
        <div class="text-xs text-text-muted">Kira/maaş oranı</div>
        <div class="text-[10px] text-text-dim mt-0.5">İstanbul 1+1, mid-level yazılımcı</div>
      </div>
    </div>

    <!-- TANTUNI INDEX -->
    <div class="bg-bg-white rounded-xl shadow-sm p-6 mb-8">
      <h2 class="text-xl font-bold text-text mb-1">Tantuni Endeksi</h2>
      <p class="text-sm text-text-secondary mb-2 leading-relaxed">
        Bir yazılımcının aylık maaşıyla kaç tantuni alabildiği, enflasyonun günlük hayata etkisini
        somut şekilde ortaya koyuyor. 2018'de orta seviye bir yazılımcı maaşıyla 450 tantuni
        alabilirken bu rakam 2023'te 294'e kadar düştü. Tantuninin fiyatı 9 yılda 25 kat artarken
        maaşlar yaklaşık 23 kat arttı. 2024 sonrasında maaş artışları tantuni fiyatını yakalamaya
        başladı ve 2026'da satın alma gücü 410 tantuniye yükseldi, ancak hâlâ 2018 seviyesinin altında.
      </p>
      <p class="text-xs text-text-muted mb-6">
        İstanbul ortalama et tantuni dürüm fiyatı baz alınmıştır. En düşük nokta: 2023 (294 tantuni).
      </p>

      <div class="space-y-2.5">
        {tantuniPerSalary.map((row, i) => {
          const maxCount = Math.max(...tantuniPerSalary.map(r => r.count));
          const pct = (row.count / maxCount) * 100;
          const isFirst = i === 0;
          const isLast = i === tantuniPerSalary.length - 1;
          return (
            <div class="flex items-center gap-3" title={`Tantuni: ₺${row.price}, Maaş: ₺${row.salary.toLocaleString('tr-TR')}`}>
              <span class="font-mono text-xs text-text-dim w-10">{row.year}</span>
              <div class="flex-1 h-7 bg-bg-chart rounded relative overflow-hidden">
                <div
                  class={`h-full rounded transition-all duration-500 ${isFirst ? 'bg-chart-2/70' : isLast ? 'bg-chart-4/60' : 'bg-accent/40'}`}
                  style={`width: ${pct}%`}
                />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 font-mono text-xs font-semibold text-text-secondary">
                  {row.count} tantuni
                </span>
              </div>
              <span class="font-mono text-xs text-text-dim w-14 text-right">₺{row.price}</span>
            </div>
          );
        })}
      </div>
      <p class="text-[10px] text-text-dim mt-2">Satır üzerine geldiğinizde maaş detayını görebilirsiniz.</p>

      <p class="source-text mt-4">
        Kaynak:
        <a href="https://www.economist.com/big-mac-index" target="_blank" rel="noopener" class="text-accent hover:underline">The Economist Big Mac Index</a>,
        <a href="https://github.com/nicatdursunlu/onceki-yazilimci-2026-anket-sonuclari" target="_blank" rel="noopener" class="text-accent hover:underline">önceki yazılımcı</a>,
        fastfoodfiyatlari.com
      </p>
    </div>

    <!-- TAX RATES -->
    <div class="bg-bg-white rounded-xl shadow-sm p-6 mb-8">
      <h2 class="text-xl font-bold text-text mb-1">Ülkelere Göre Efektif Vergi Yükü</h2>
      <p class="text-sm text-text-secondary mb-2 leading-relaxed">
        Aşağıdaki tablo, orta seviye bir yazılımcının brüt maaşından eline geçen
        net tutarı etkileyen toplam vergi yükünü ülkelere göre karşılaştırıyor.
        Türkiye'de maaşlı bir çalışanın gelir vergisi, SGK işçi payı, işsizlik sigortası
        ve damga vergisi kesintileri toplamda yaklaşık %39 efektif oran oluşturuyor.
        Serbest meslek olarak (freelancer) çalışanlarda stopaj dahil edildiğinde bu oran
        %42'ye çıkabiliyor. Kendi şirketini kuran yazılımcılar için ise kurumlar vergisi
        ve SGK işveren payı dahil toplam yük %45 civarına ulaşabiliyor.
      </p>
      <p class="text-xs text-text-muted mb-6">
        Orta seviye bir Türk yazılımcı (₺102.500 net/ay) yıllık net $33.200 kazanırken
        aynı seviyedeki bir ABD'li yazılımcı $82.000 kazanıyor, yaklaşık 2,5 kat fark.
      </p>

      <div class="space-y-2">
        {[...taxData].sort((a, b) => a.rate - b.rate).map(row => {
          const isHighlight = row.highlight;
          return (
            <div class={`flex items-center gap-3 py-1.5 ${isHighlight ? 'bg-chart-4/5 -mx-2 px-2 rounded-lg' : ''}`}>
              <span class="text-sm w-5">{row.flag}</span>
              <span class={`text-sm w-48 shrink-0 ${isHighlight ? 'font-semibold text-text' : 'text-text-body'}`}>{row.country}</span>
              <div class="flex-1 h-5 bg-bg-chart rounded overflow-hidden">
                <div
                  class={`h-full rounded ${isHighlight ? 'bg-chart-4/60' : 'bg-accent/40'}`}
                  style={`width: ${(row.rate / 58) * 100}%`}
                />
              </div>
              <span class={`font-mono text-xs w-10 text-right ${isHighlight ? 'text-chart-4 font-bold' : 'text-text-muted'}`}>
                %{row.rate}
              </span>
              <span class="font-mono text-xs text-text-dim w-24 text-right">${row.netUSD.toLocaleString('en-US')}/yıl</span>
            </div>
          );
        })}
      </div>

      <p class="source-text mt-4">
        Kaynak:
        <a href="https://taxsummaries.pwc.com/turkey/individual/taxes-on-personal-income" target="_blank" rel="noopener" class="text-accent hover:underline">PwC Tax Summaries</a>,
        <a href="https://www.gib.gov.tr/gibmevzuat" target="_blank" rel="noopener" class="text-accent hover:underline">GİB Mevzuat</a>,
        <a href="https://www.oecd.org/tax/tax-policy/taxing-wages-turkey.pdf" target="_blank" rel="noopener" class="text-accent hover:underline">OECD Taxing Wages</a>
      </p>
    </div>

    <!-- TURKEY TAX BREAKDOWN -->
    <div class="bg-bg-white rounded-xl shadow-sm p-6 mb-8">
      <h2 class="text-xl font-bold text-text mb-1">Türkiye'deki Gizli Vergi Kalemleri</h2>
      <p class="text-sm text-text-secondary mb-2 leading-relaxed">
        Bir yazılımcının maaş bordrosunda görünen gelir vergisinin yanı sıra, SGK kesintileri,
        damga vergisi, stopaj ve işveren payı gibi kalemler toplam vergi yükünü önemli ölçüde
        artırıyor. Şirket sahibi yazılımcılar ise bunlara ek olarak kurumlar vergisi, KDV
        ve geçici vergi ödemekle yükümlü.
      </p>
      <p class="text-xs text-text-muted mb-6">
        Aşağıdaki tablo, Türkiye'deki bir yazılımcının karşılaştığı tüm vergi ve kesinti
        kalemlerini göstermektedir. Oranlar 2024-2025 mevzuatına göre hesaplanmıştır.
      </p>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-2 text-xs text-text-muted font-medium">Vergi / Kesinti</th>
              <th class="text-right py-2 text-xs text-text-muted font-medium">Oran (%)</th>
              <th class="text-left py-2 pl-6 text-xs text-text-muted font-medium">Açıklama</th>
            </tr>
          </thead>
          <tbody>
            {turkeyTaxBreakdown.map(row => (
              <tr class="border-b border-border/50">
                <td class="py-2.5 text-xs text-text font-medium">{row.name}</td>
                <td class="py-2.5 font-mono text-xs text-chart-4 text-right">%{row.rate}</td>
                <td class="py-2.5 text-xs text-text-muted pl-6">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="source-text mt-4">
        Kaynak:
        <a href="https://taxsummaries.pwc.com/turkey/individual/taxes-on-personal-income" target="_blank" rel="noopener" class="text-accent hover:underline">PwC Tax Summaries Turkey</a>,
        <a href="https://www.gib.gov.tr/gibmevzuat" target="_blank" rel="noopener" class="text-accent hover:underline">GİB Mevzuat</a>,
        <a href="https://www.mevzuat.gov.tr/MevzuatMetin/1.5.193.pdf" target="_blank" rel="noopener" class="text-accent hover:underline">193 Sayılı Gelir Vergisi Kanunu</a>,
        <a href="https://www.sgk.gov.tr/Content/Post/20130108-1" target="_blank" rel="noopener" class="text-accent hover:underline">SGK Prim Oranları</a>,
        <a href="https://www.resmigazete.gov.tr" target="_blank" rel="noopener" class="text-accent hover:underline">Resmi Gazete</a>,
        <a href="https://www.oecd.org/tax/tax-policy/taxing-wages-turkey.pdf" target="_blank" rel="noopener" class="text-accent hover:underline">OECD Taxing Wages Turkey</a>,
        <a href="https://www2.deloitte.com/tr/tr/pages/tax/articles/turkey-tax-guide.html" target="_blank" rel="noopener" class="text-accent hover:underline">Deloitte Turkey Tax Guide</a>
      </p>
    </div>

    <!-- RENT vs SALARY -->
    <div class="bg-bg-white rounded-xl shadow-sm p-6 mb-8">
      <h2 class="text-xl font-bold text-text mb-1">Kira ve Maaş: Uluslararası Karşılaştırma</h2>
      <p class="text-sm text-text-secondary mb-2 leading-relaxed max-w-[700px]">
        Bir yazılımcının şehir merkezinde 1+1 daire kirası, aylık net maaşının ne
        kadarını yiyor? İstanbul %43 ile listenin en üst sırasında - Berlin'in iki
        katından fazla, Tallinn'in üç katı.
      </p>
      <p class="text-xs text-text-muted mb-6">
        Nominal kira düşük görünse de ($1.083), düşük maaşla birleşince oran dramatik oluyor.
      </p>

      <div class="space-y-2">
        {sortedRent.map(row => {
          const isHighlight = row.flag === '🇹🇷';
          return (
            <div class={`flex items-center gap-3 py-1.5 ${isHighlight ? 'bg-chart-4/5 -mx-2 px-2 rounded-lg' : ''}`}>
              <span class="text-sm w-5">{row.flag}</span>
              <span class={`text-sm w-28 ${isHighlight ? 'font-semibold text-text' : 'text-text-body'}`}>{row.city}</span>
              <div class="flex-1 h-5 bg-bg-chart rounded overflow-hidden">
                <div
                  class={`h-full rounded ${isHighlight ? 'bg-chart-4/60' : 'bg-accent/40'}`}
                  style={`width: ${(row.ratio / maxRatio) * 100}%`}
                />
              </div>
              <span class={`font-mono text-xs w-10 text-right ${isHighlight ? 'text-chart-4 font-bold' : 'text-text-muted'}`}>
                %{row.ratio}
              </span>
              <span class="font-mono text-xs text-text-dim w-28 text-right">
                ${row.rent} / ${row.salary}
              </span>
            </div>
          );
        })}
      </div>

      <p class="source-text mt-4">
        Kaynak:
        <a href="https://www.numbeo.com" target="_blank" rel="noopener" class="text-accent hover:underline">Numbeo</a>,
        <a href="https://www.expatistan.com" target="_blank" rel="noopener" class="text-accent hover:underline">Expatistan</a>
        · 1+1 daire, şehir merkezi, Ocak 2025
      </p>
    </div>

    <!-- EDITORIAL CONCLUSION -->
    <div class="bg-bg-chart rounded-xl p-6 mb-8">
      <h2 class="text-lg font-bold text-text mb-3">Zamlar Neden Hissedilmiyor?</h2>
      <p class="text-sm text-text-body leading-relaxed mb-3">
        Türkiye'deki bir yazılımcının nominal maaşı 2018'den bu yana 16 kat artmış
        olsa da, bağımsız enflasyon verileri fiyatların yaklaşık 60 kat yükseldiğini
        gösteriyor. Bu, <strong>gerçek satın alma gücünün %{purchasingPowerLoss} oranında
        eridiği</strong> anlamına geliyor.
      </p>
      <p class="text-sm text-text-body leading-relaxed mb-3">
        Tabloya vergi yükü eklendiğinde durum daha da netleşiyor: yaklaşık %39'luk efektif
        vergi oranıyla Türkiye orta sıralarda yer alsa da net maaşın dolar
        karşılığı ($33.200/yıl) gelişmiş ülkelerin oldukça altında kalıyor.
      </p>
      <p class="text-sm text-text-body leading-relaxed">
        Kira/maaş oranında İstanbul %43 ile zirvede. Berlin'de (%19) ya da
        Tallinn'de (%14) aynı mesleği yapan bir yazılımcı, maaşının çok daha az
        bir kısmını barınmaya ayırıyor. Bu üç faktör - enflasyon, vergi, kira -
        bir araya geldiğinde, nominal zam oranlarının neden "hissedilmediğini" açıklıyor.
      </p>
    </div>
  </section>

  <IznimvarBanner />
  <Footer />
</Layout>
