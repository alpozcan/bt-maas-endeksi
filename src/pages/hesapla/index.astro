---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import IznimvarBanner from '../../components/IznimvarBanner.astro';
import '../../styles/global.css';
import SalaryCalculator from '../../components/SalaryCalculator';
---

<Layout title="Maaşını Hesapla — yazılımmaaş" active="hesapla" description="Yazılım sektöründe maaşın kaçıncı yüzdelikte? 5.002 geliştiricinin verileriyle karşılaştır.">
  <section class="max-w-[960px] mx-auto px-6 pt-16 pb-8">
    <h1 class="text-3xl font-bold text-text tracking-tight mb-2">Maaşın Nerede?</h1>
    <p class="text-sm text-text-secondary leading-relaxed max-w-[600px] mb-8">
      Aylık net maaşını gir, seviye ve pozisyon filtrelerini seç — 5.002 yazılımcı
      arasında kaçıncı yüzdelikte olduğunu öğren.
    </p>

    <div class="bg-bg-white rounded-xl shadow-sm p-6">
      <SalaryCalculator client:load />
    </div>
  </section>

  <IznimvarBanner />
  <Footer />
</Layout>
